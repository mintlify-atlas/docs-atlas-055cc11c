  "keyFeatures": [
    "Automatically answers Kahoot quizzes with a perfect score",
    "Search for quizzes by name (requires Kahoot login) or by UUID",
    "Two-factor authentication (2FA) support",
    "WebSocket-based Kahoot client simulation",
    "JavaScript challenge solver for session token decoding",
    "Search-only mode to inspect quiz answers without joining",
    "Debug mode for verbose output"
  ],
  "publicApiSurface": [
