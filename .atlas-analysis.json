    "kbot -n <nick> -p <pin> -q <quizName> -e <email> -a <password>",
    "kbot -s -i <quizID>",
    "kbot -s -q <quizName> -e <email> -a <password>",
    "kbot -d (debug mode)",
    "kbot -m <maxCount>",
    "Kahoot(pin, nickname, quizName, quizID, maxCount, DEBUG)",
    "Kahoot.authenticate(email, password)",
    "Kahoot.startGame()",
    "Kahoot.search()",
    "Kahoot.checkPin()",
    "Kahoot.parseAnswers(quiz, debug)"
  ]
